@* ────────────────────────────────────────────────────────────────────────
   Home.razor — Pagina principale del feed (route "/home").
   Struttura a due colonne (RadzenRow/RadzenColumn):
     - Sinistra (3/12): Card profilo, Compleanni, Avvisi
     - Destra (9/12):  Box creazione post + feed cronologico
   Implementa IDisposable per fermare l'auto-refresh loop quando
   l'utente lascia la pagina.
   Ciclo di vita:
     OnInitializedAsync → verifica sessione, carica dati, avvia loop 500ms
     Dispose → ferma il loop tramite CancellationToken
   Il loop ogni 500ms (AutoRefreshLoop) ricarica post/avvisi/compleanni
   dal DB per mantenere il feed aggiornato in tempo reale.
   La cache distribuita (Memurai) evita che il DB venga saturato.
   ──────────────────────────────────────────────────────────────────────── *@

@page "/home"
@implements IAsyncDisposable
@using Microsoft.AspNetCore.SignalR.Client
@using social_V0._0._1.Utils
@inject IPostService PostSvc
@inject IUtenteService UtenteSvc
@inject IAvvisoService AvvisoSvc
@inject NavigationManager NavManager
@inject ISessionService Session
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div class="main-container">
    <div class="center-content">
        <div style="width: 100%; max-width: 1600px; padding: 0 24px;">

            @* Alert di errore globale (problemi di connessione, DB down, ecc.) *@
            @if (!string.IsNullOrEmpty(messaggioErrore))
            {
                <RadzenAlert AlertStyle="AlertStyle.Danger" Class="rz-mb-4" Variant="Variant.Flat">
                    @messaggioErrore
                </RadzenAlert>
            }

            @* Griglia principale: Sinistra (colonna) + Destra (feed) *@
            <RadzenRow Gap="2.5rem">

                @* ────────────────────────────────────────────────────────
                   COLONNA SINISTRA (3/12 su desktop, 12/12 su mobile)
                   Contiene: Card profilo, Compleanni, Avvisi
                   La colonna è sticky (position: sticky, top: 85px)
                   per rimanere visibile durante lo scroll.
                   ──────────────────────────────────────────────────────── *@
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenStack Gap="1.5rem" Style="position: sticky; top: 85px;">

                        @* Card profilo utente loggato *@
                        @if (utenteLoggato != null)
                        {
                            <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2" Style="text-align: center; border-top: 5px solid var(--brand-primary); background: white;">
                                <div style="width: 100px; height: 100px; border-radius: 50%; overflow: hidden; margin: 0 auto 15px auto; border: 3px solid var(--brand-border);">
                                    @if (utenteLoggato.FotoUrl != null)
                                    {
                                        <img src="@ImageHelper.ToBase64(utenteLoggato.FotoUrl)" style="width: 100%; height: 100%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div style="width:100%; height:100%; background: var(--brand-primary); color: white; display:flex; align-items:center; justify-content:center; font-size: 2rem; font-weight:bold;">
                                            @utenteLoggato.Nome[0]@utenteLoggato.Cognome[0]
                                        </div>
                                    }
                                </div>
                                <RadzenText TextStyle="TextStyle.H6" Class="rz-m-0" Style="color: var(--brand-primary); font-weight: 700;">@utenteLoggato.Nome @utenteLoggato.Cognome</RadzenText>
                                <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--brand-action); font-weight: 600;">@utenteLoggato.Dipartimento</RadzenText>
                            </RadzenCard>
                        }

                        @* Card Compleanni: elenco utenti che compiono gli anni oggi *@
                        <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-1" Style="background: white;">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Class="rz-mb-4">
                                @* Icona torta *@
                                <RadzenIcon Icon="cake" IconColor="var(--brand-action)" />
                                <RadzenText TextStyle="TextStyle.Subtitle1" Style="color: var(--brand-primary); font-weight: bold;" Class="rz-m-0">Compleanni</RadzenText>
                            </RadzenStack>
                            <RadzenSeparator Style="background-color: var(--brand-border); height: 1px;" />
                            <RadzenStack Gap="1rem" Class="rz-mt-4">
                                @if (listaCompleanni == null || !listaCompleanni.Any())
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" Class="rz-color-text-secondary">Nessun compleanno oggi 🎉</RadzenText>
                                }
                                else
                                {
                                    @foreach (var festeggiato in listaCompleanni)
                                    {
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.8rem">
                                            <div style="width: 32px; height: 32px; border-radius: 50%; overflow: hidden; flex-shrink: 0; @GetCompleannoStyle(festeggiato.FotoUrl)">
                                                @if (festeggiato.FotoUrl != null)
                                                {
                                                    <img src="@ImageHelper.ToBase64(festeggiato.FotoUrl)" style="width: 100%; height: 100%; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    @festeggiato.Nome[0]@festeggiato.Cognome[0]
                                                }
                                            </div>
                                            <RadzenText TextStyle="TextStyle.Body2" Class="rz-font-weight-bold rz-m-0">@festeggiato.Nome @festeggiato.Cognome</RadzenText>
                                        </RadzenStack>
                                    }
                                }
                            </RadzenStack>
                        </RadzenCard>

                        @* Card Avvisi Aziendali *@
                        <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-1" Style="background-color: #fefefe; border-left: 5px solid #ff9800;">
                            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem" Class="rz-mb-4">
                                <RadzenIcon Icon="campaign" IconColor="#ff9800" />
                                <RadzenText TextStyle="TextStyle.Subtitle1" Style="color: #e65100; font-weight: bold;" Class="rz-m-0">Avvisi</RadzenText>
                            </RadzenStack>
                            <RadzenStack Gap="0.5rem">
                                @if (listaAvvisi == null || !listaAvvisi.Any())
                                {
                                    <RadzenText TextStyle="TextStyle.Caption">Nessun avviso presente.</RadzenText>
                                }
                                else
                                {
                                    @foreach (var avviso in listaAvvisi)
                                    {
                                        <div style="border-bottom: 1px solid #eee; padding-bottom: 8px;">
                                            <RadzenText TextStyle="TextStyle.Body2" Style="font-weight: bold; color: #333;">@avviso.Titolo</RadzenText>
                                            <RadzenText TextStyle="TextStyle.Caption">@avviso.Messaggio</RadzenText>
                                        </div>
                                    }
                                }
                            </RadzenStack>
                        </RadzenCard>

                    </RadzenStack>
                </RadzenColumn>

                @* ────────────────────────────────────────────────────────
                   COLONNA DESTRA (9/12 su desktop)
                   Contiene: Box creazione post + Feed dei post
                   ──────────────────────────────────────────────────────── *@
                <RadzenColumn Size="12" SizeMD="9">
                    <RadzenStack Gap="2rem">

                        @* Box creazione nuovo post *@
                        <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2 rz-p-8" Style="background: white;">
                            <RadzenStack Gap="1.5rem">
                                <div style="display: flex; gap: 20px; align-items: flex-start;">
                                    @* Avatar utente a sinistra della textarea *@
                                    @if (utenteLoggato != null)
                                    {
                                        <div style="width: 50px; height: 50px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 2px solid var(--brand-border);">
                                            @if (utenteLoggato.FotoUrl != null)
                                            {
                                                <img src="@ImageHelper.ToBase64(utenteLoggato.FotoUrl)" style="width: 100%; height: 100%; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background: var(--brand-primary); color:white; font-weight:bold; font-size: 0.9rem;">
                                                    @utenteLoggato.Nome[0]@utenteLoggato.Cognome[0]
                                                </div>
                                            }
                                        </div>
                                    }
                                    @* TextArea multi-riga per il contenuto del post *@
                                    <RadzenTextArea @bind-Value="@nuovoPostContenuto"
                                                    Placeholder="Cosa vuoi condividere con i colleghi?"
                                                    Rows="3"
                                                    Class="rz-w-100"
                                                    Style="border-radius: 12px; border: 1px solid var(--brand-border); padding: 15px; font-size: 1.1rem;" />
                                </div>
                                @* Pulsante Pubblica, disabilitato se testo vuoto o utente non loggato *@
                                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End">
                                    <RadzenButton Click="@PubblicaPost"
                                                  Text="Pubblica"
                                                  Icon="send"
                                                  ButtonStyle="ButtonStyle.Primary"
                                                  Style="background-color: var(--brand-primary); border-radius: 25px; padding: 0 35px;"
                                                  @disabled="@(string.IsNullOrWhiteSpace(nuovoPostContenuto) || utenteLoggato == null)" />
                                </RadzenStack>
                            </RadzenStack>
                        </RadzenCard>

                        @* Feed dei post: ogni post è una RadzenCard separata *@
                        @if (posts != null)
                        {
                            @foreach (var post in posts)
                            {
                                <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2 rz-p-8" Style="background: white;">
                                    <RadzenStack Gap="1.5rem">
                                        @* Intestazione: avatar autore + nome + data *@
                                        <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1.2rem">
                                            <div style="width: 60px; height: 60px; border-radius: 50%; overflow: hidden; border: 2px solid var(--brand-border); flex-shrink: 0;">
                                                @if (post.FotoUrl != null) {
                                                    <img src="@post.FotoUrlBase64" style="width: 100%; height: 100%; object-fit: cover;" />
                                                } else {
                                                    <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background: var(--brand-primary); color:white; font-weight:bold;">@post.Iniziali</div>
                                                }
                                            </div>
                                            <RadzenStack Gap="0">
                                                @* Nome autore + badge dipartimento *@
                                                <RadzenText TextStyle="TextStyle.H6" Class="rz-m-0" Style="font-weight: 700; color: var(--brand-primary);">@post.Nome @post.Cognome</RadzenText>
                                                <RadzenText TextStyle="TextStyle.Body2" Class="rz-m-0 rz-color-text-secondary">
                                                    <span style="color: var(--brand-action); font-weight: 600;">@post.Dipartimento</span>
                                                    <span style="margin: 0 8px;">•</span>
                                                    @* Conversione da UTC a fuso Italia *@
                                                    <span style="font-size: 0.85rem;">
                                                        @TimeZoneInfo.ConvertTimeFromUtc(
                                                            DateTime.SpecifyKind(post.DataPubblicazione, DateTimeKind.Utc),
                                                            TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time")
                                                        ).ToString("dd MMMM yyyy, HH:mm")
                                                    </span>
                                                </RadzenText>
                                            </RadzenStack>
                                        </RadzenStack>

                                        @* Contenuto del post (testo, con white-space preservato) *@
                                        <div style="padding: 0 5px;">
                                            <RadzenText TextStyle="TextStyle.H6" Style="white-space: pre-wrap; line-height: 1.6; font-weight: 400; color: #2c3e50; font-size: 1.25rem;">
                                                @post.Contenuto
                                            </RadzenText>
                                        </div>

                                        <RadzenSeparator Style="background-color: var(--brand-border); opacity: 0.3;" />

                                        @* Barra azioni: Like (toggle) e Commenta (placeholder) *@
                                        <RadzenStack Orientation="Orientation.Horizontal" Gap="2rem">
                                            @* Pulsante Like: cambia icona e colore in base a IsLikedByMe *@
                                            <RadzenButton Variant="Variant.Text"
                                                          Icon="@(post.IsLikedByMe ? "favorite" : "favorite_border")"
                                                          Text="@(post.LikeCount > 0 ? post.LikeCount.ToString() : "")"
                                                          Style="@(post.IsLikedByMe ? "color: #ed4956;" : "color: var(--brand-action);")"
                                                          Click="@(() => GestisciLike(post))" />
                                            @* Pulsante Commenta (non ancora implementato) *@
                                            <RadzenButton Variant="Variant.Text" Icon="chat_bubble_outline" Text="Commenta" Style="color: var(--brand-action);" />
                                        </RadzenStack>
                                    </RadzenStack>
                                </RadzenCard>
                            }
                        }
                    </RadzenStack>
                </RadzenColumn>

            </RadzenRow>
        </div>
    </div>
</div>

@code {
    private List<PostViewModel> posts = null!;     // Feed completo dei post
    private List<Avviso> listaAvvisi = null!;      // Avvisi aziendali attivi
    private List<Utente> listaCompleanni = null!;  // Utenti che compiono gli anni oggi
    private Utente utenteLoggato = null!;          // Utente correntemente loggato
    private HubConnection _hubConnection = null!; // Connessione SignalR per notifiche real-time
    private string nuovoPostContenuto = "";        // Testo del nuovo post in fase di scrittura
    private string? messaggioErrore;               // Eventuale messaggio di errore visibile in pagina

    private string GetCompleannoStyle(byte[]? fotoUrl) =>
        fotoUrl == null
            ? "background-color: var(--brand-action); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: bold;"
            : "";

    //
    // OnInitializedAsync: step di inizializzazione del componente.
    // Flusso:
    // 1. Verifica che l'utente sia loggato; altrimenti redirect a /login
    // 2. Copia il riferimento dell'utente loggato
    // 3. Carica post, avvisi e compleanni (CaricaDati)
    // 4. Crea e avvia la connessione SignalR al NotificationHub
    //
    protected override async Task OnInitializedAsync()
    {
        if (Session.UtenteLoggato == null)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        utenteLoggato = Session.UtenteLoggato;
        await CaricaDati();
        await AvviaSignalR();
    }

    //
    // Crea e avvia la connessione al NotificationHub.
    // Si sottoscrive agli eventi "NewPost" e "LikeChanged":
    // alla ricezione di uno dei due, ricarica i dati via CaricaDati().
    // La connessione viene chiusa in Dispose().
    //
    private async Task AvviaSignalR()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavManager.ToAbsoluteUri("/notificationhub"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On("NewPost", async () =>
            {
                await InvokeAsync(async () =>
                {
                    await CaricaDati();
                    StateHasChanged();
                });
            });

            _hubConnection.On("LikeChanged", async () =>
            {
                await InvokeAsync(async () =>
                {
                    await CaricaDati();
                    StateHasChanged();
                });
            });

            await _hubConnection.StartAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SignalR connection error: {ex.Message}");
        }
    }

    //
    // DisposeAsync: ferma e rilascia la connessione SignalR quando il
    // componente viene rimosso dal render tree (navigazione ad altra
    // pagina o chiusura del circuito).
    //
    public async ValueTask DisposeAsync()
    {
        if (_hubConnection != null)
        {
            await _hubConnection.DisposeAsync();
        }
    }

    //
    // Carica post, avvisi e compleanni dal DB (con fallback cache).
    // In caso di eccezione (es. DB down), mostra messaggio nell'alert
    // invece di far crashare la pagina.
    //
    private async Task CaricaDati()
    {
        try
        {
            posts = await PostSvc.GetAllPostsAsync(utenteLoggato.UtenteId);
            listaAvvisi = await AvvisoSvc.GetAvvisiAttiviAsync();
            listaCompleanni = await UtenteSvc.GetCompleanniOggiAsync();
            messaggioErrore = null;
        }
        catch (Exception ex)
        {
            messaggioErrore = $"Errore caricamento dati: {ex.Message}";
        }
    }

    //
    // Toggle like con optimistic update:
    // 1. Aggiorna SUBITO l'interfaccia (isLiked + conteggio)
    // 2. Poi chiama il DB per persistenza
    // 3. Se il DB fallisce, ricarica lo stato reale dal server
    // (rollback dell'optimistic update)
    //
    private async Task GestisciLike(PostViewModel post)
    {
        if (utenteLoggato == null) return;
        try
        {
            post.IsLikedByMe = !post.IsLikedByMe;
            if (post.IsLikedByMe) post.LikeCount++; else post.LikeCount--;
            await PostSvc.ToggleLikeAsync(post.PostId, utenteLoggato.UtenteId);
        }
        catch (Exception ex)
        {
            await CaricaDati();
            Console.WriteLine($"Errore Like: {ex.Message}");
        }
    }

    //
    // Pubblica un nuovo post: lo salva nel DB, ricarica il feed
    // e pulisce il campo di testo. In caso di errore (DB, validazione),
    // mostra messaggio nell'alert.
    //
    private async Task PubblicaPost()
    {
        if (!string.IsNullOrWhiteSpace(nuovoPostContenuto) && utenteLoggato != null)
        {
            try
            {
                await PostSvc.InsertPostAsync(utenteLoggato.UtenteId, nuovoPostContenuto);
                nuovoPostContenuto = "";
                await CaricaDati();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                messaggioErrore = $"Errore pubblicazione: {ex.Message}";
            }
        }
    }
}