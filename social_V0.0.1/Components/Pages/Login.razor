@page "/"
@page "/login"
@using Microsoft.Data.SqlClient
@using Dapper
@using BCrypt.Net
@using social_V0._0._1.Models
@using social_V0._0._1.Services
@inject IConfiguration Config
@inject NavigationManager NavManager
@inject SessionService Session
@rendermode InteractiveServer

<PageTitle>Login</PageTitle>

<RadzenCard class="rz-shadow-10 rz-p-12 login-card">

    <RadzenText TextStyle="TextStyle.H4"
                Class="rz-text-align-center rz-mb-6"
                Style="font-weight: 800; color: var(--brand-primary); font-family: 'Segoe UI', sans-serif;">
        Accedi
    </RadzenText>

    @if (!string.IsNullOrEmpty(messaggio))
    {
        <RadzenAlert AlertStyle="AlertStyle.Danger" Class="rz-mb-4" Variant="Variant.Flat">
            @messaggio
        </RadzenAlert>
    }

    @* Usiamo un contenitore che intercetta il tasto Invio *@
    <div @onkeydown="@HandleKeyDown">
        <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Email</RadzenText>
        <RadzenTextBox @bind-Value="@email" Class="w-100 rz-mb-4" placeholder="Inserisci email..." />

        <RadzenText TextStyle="TextStyle.Subtitle2" TagName="TagName.H3">Password</RadzenText>
        <RadzenPassword @bind-Value="@password" Class="w-100 rz-mb-4" placeholder="Inserisci password..." />

        <RadzenButton Text="Accedi"
                      Click="@EffettuaLogin"
                      Class="w-100 rz-mt-4"
                      Style="background-color: var(--brand-primary); border-radius: var(--brand-radius);" />

        <div class="rz-text-align-center rz-mt-4">
            <RadzenText TextStyle="TextStyle.Body2">
                Non sei registrato?
                <RadzenLink Text="Crea account" Path="/signup" />
            </RadzenText>
        </div>
    </div>

    <div class="login-footer rz-mt-6">
        <RadzenLink Text="Termini e condizioni"
                    Path="/eula"
                    Style="font-size: 0.9rem; color: var(--brand-action); font-weight: 600;" />
    </div>

</RadzenCard>

@code {
    private string email = "";
    private string password = "";
    private string messaggio = "";

    protected override void OnInitialized()
    {
        if (Session.UtenteLoggato != null)
        {
            NavManager.NavigateTo("/home");
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await EffettuaLogin();
        }
    }

    private async Task EffettuaLogin()
    {
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(password))
        {
            messaggio = "Inserisci credenziali valide.";
            return;
        }

        try
        {
            using (var db = new SqlConnection(Config.GetConnectionString("DefaultConnection")))
            {
                var sql = "SELECT * FROM dbo.Utenti WHERE Email = @User";
                var utente = await db.QueryFirstOrDefaultAsync<Utente>(sql, new { User = email });

                if (utente != null && BCrypt.Verify(password, utente.Password))
                {
                    Session.Login(utente);
                    NavManager.NavigateTo("/home", forceLoad: true);
                }
                else
                {
                    messaggio = "Email o Password errati.";
                }
            }
        }
        catch (Exception ex)
        {
            messaggio = "Errore di connessione al database.";
        }
    }
}