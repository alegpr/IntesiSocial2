@* ────────────────────────────────────────────────────────────────────────
   Profilo.razor — Pagina profilo utente loggato (route "/profilo").
   A due colonne:
     - SINISTRA (4/12 sticky): Card riepilogo (foto, nome, email,
       dipartimento, data nascita) + pulsanti azione (Modifica profilo,
       Cambia password, Torna alla Home)
     - DESTRA (8/12): Form modifica profilo (toggle), form cambio
       password (toggle) + bacheca personale "I tuoi post"
   I form modifica profilo e cambio password sono mutuamente esclusivi:
     - ApriModifica() chiude mostraCambioPassword
     - ApriCambioPassword() chiude modalitaModifica
   Ciclo di vita:
     OnInitializedAsync → verifica sessione, carica profilo e post
   ──────────────────────────────────────────────────────────────────────── *@
@page "/profilo"
@using social_V0._0._1.Utils
@inject IPostService PostSvc
@inject IUtenteService UtenteSvc
@inject NavigationManager NavManager
@inject ISessionService Session
@rendermode InteractiveServer

<PageTitle>Profilo</PageTitle>

<div class="main-container">
    <div class="center-content">
        <div style="width: 100%; max-width: 1200px; padding: 0 24px;">

            <RadzenRow Gap="2rem">

                @* ────────────────────────────────────────────────────────
                   COLONNA SINISTRA: Card riepilogo utente + pulsanti
                   Sticky (top: 85px per stare sotto l'header fisso).
                   ──────────────────────────────────────────────────────── *@
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenStack Gap="1.5rem" Style="position: sticky; top: 85px;">

                        @* Card riepilogo: foto (o iniziali), nome, email, dip, data nascita *@
                        <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2" Style="background: white; border-top: 5px solid var(--brand-primary);">
                            <RadzenStack Gap="1rem" AlignItems="AlignItems.Center">

                                @* Foto profilo 140px circolare; se assente mostra iniziali su sfondo brand *@
                                <div style="width: 140px; height: 140px; border-radius: 50%; overflow: hidden; border: 4px solid var(--brand-border);">
                                    @if (utente.FotoUrl != null)
                                    {
                                        <img src="@ImageHelper.ToBase64(utente.FotoUrl)" style="width: 100%; height: 100%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div style="width:100%; height:100%; background: var(--brand-primary); color: white; display:flex; align-items:center; justify-content:center; font-size: 3rem; font-weight:bold;">
                                            @(utente.Nome.Length > 0 ? utente.Nome[0].ToString() : "")@(utente.Cognome.Length > 0 ? utente.Cognome[0].ToString() : "")
                                        </div>
                                    }
                                </div>

                                <RadzenText TextStyle="TextStyle.H5" Class="rz-m-0" Style="color: var(--brand-primary); font-weight: 700; text-align: center;">
                                    @utente.Nome @utente.Cognome
                                </RadzenText>
                                <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--brand-action); font-weight: 600;">
                                    @utente.Email
                                </RadzenText>
                                <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #555;">
                                    @utente.Dipartimento
                                </RadzenText>

                                @if (utente.DataDiNascita.HasValue)
                                {
                                    <RadzenText TextStyle="TextStyle.Caption" Style="color: #888;">
                                        🎂 @utente.DataDiNascita.Value.ToString("dd MMMM yyyy")
                                    </RadzenText>
                                }

                            </RadzenStack>
                        </RadzenCard>

                        @* Pulsanti azione: aprono rispettiva sezione a destra *@
                        <RadzenButton Text="Modifica profilo"
                                      Icon="edit"
                                      ButtonStyle="ButtonStyle.Primary"
                                      Click="@ApriModifica"
                                      Class="w-100"
                                      Style="background-color: var(--brand-primary); border-radius: 8px;" />

                        <RadzenButton Text="Cambia password"
                                      Icon="lock"
                                      Click="@ApriCambioPassword"
                                      Class="w-100"
                                      Style="background-color: #ff9800; border-radius: 8px; color: white; font-weight: 600;" />

                        <RadzenButton Text="Torna alla Home"
                                      Icon="home"
                                      ButtonStyle="ButtonStyle.Light"
                                      Click="@(() => NavManager.NavigateTo("/home"))"
                                      Class="w-100"
                                      Style="border-radius: 8px; color: var(--brand-primary);" />

                    </RadzenStack>
                </RadzenColumn>

                @* ────────────────────────────────────────────────────────
                   COLONNA DESTRA: Form modifica profilo / cambio password
                   (toggle) + bacheca post utente.
                   ──────────────────────────────────────────────────────── *@
                <RadzenColumn Size="12" SizeMD="8">
                    <RadzenStack Gap="2rem">

                        @* ── FORM MODIFICA PROFILO ──
                           Visibile solo quando modalitaModifica == true.
                           Pre-compilato al submit con dati correnti (ApriModifica).
                           Foto via InputFile nativo Blazor → byte[] → preview base64.
                           Dati inviati a UtenteSvc.UpdateUtenteAsync().
                           Aggiorna anche Session.UtenteLoggato dopo salvataggio.
                        *@
                        @if (modalitaModifica)
                        {
                            <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2 rz-p-8" Style="background: white; border-left: 5px solid var(--brand-primary);">
                                <RadzenText TextStyle="TextStyle.H5" Class="rz-mb-6" Style="font-weight: 700; color: var(--brand-primary);">Modifica Profilo</RadzenText>

                                <RadzenStack Gap="1.5rem">
                                    @* Nome e cognome in riga affiancati *@
                                    <RadzenRow>
                                        <RadzenColumn Size="6">
                                            <RadzenFormField Text="Nome" Style="width:100%">
                                                <RadzenTextBox @bind-Value="@modificaNome" Style="width: 100%; height: 42px;" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                        <RadzenColumn Size="6">
                                            <RadzenFormField Text="Cognome" Style="width:100%">
                                                <RadzenTextBox @bind-Value="@modificaCognome" Style="width: 100%; height: 42px;" />
                                            </RadzenFormField>
                                        </RadzenColumn>
                                    </RadzenRow>

                                    <RadzenFormField Text="Dipartimento" Style="width:100%">
                                        <RadzenTextBox @bind-Value="@modificaDipartimento" Style="width: 100%; height: 42px;" />
                                    </RadzenFormField>

                                    <RadzenFormField Text="Data di Nascita" Style="width:100%">
                                        <RadzenDatePicker @bind-Value="@modificaDataNascita" DateFormat="dd/MM/yyyy" Style="width:100%" />
                                    </RadzenFormField>

                                    @* InputFile nativo Blazor: max 5MB, solo immagini; byte[] → preview base64 al volo *@
                                    <RadzenFormField Text="Foto Profilo" Style="width:100%">
                                        <InputFile OnChange="@OnFotoCambiata" Class="form-control" accept="image/*" />
                                        @if (modificaFotoPreview != null)
                                        {
                                            <div style="margin-top: 8px;">
                                                <img src="@modificaFotoPreview" style="max-width: 120px; max-height: 120px; border-radius: 8px;" />
                                            </div>
                                        }
                                    </RadzenFormField>

                                    @* Feedback salvataggio: success (verde) o errore (rosso) *@
                                    @if (!string.IsNullOrEmpty(messaggioModifica))
                                    {
                                        <RadzenAlert AlertStyle="AlertStyle.Danger" Variant="Variant.Flat">
                                            @messaggioModifica
                                        </RadzenAlert>
                                    }

                                    <RadzenRow>
                                        <RadzenColumn Size="6">
                                            <RadzenButton Text="Salva"
                                                          Click="@SalvaModifiche"
                                                          Style="width: 100%; background-color: var(--brand-primary); border-radius: 8px; font-weight: bold; height: 45px;" />
                                        </RadzenColumn>
                                        <RadzenColumn Size="6">
                                            <RadzenButton Text="Annulla"
                                                          ButtonStyle="ButtonStyle.Light"
                                                          Click="@AnnullaModifica"
                                                          Style="width: 100%; border-radius: 8px; height: 45px;" />
                                        </RadzenColumn>
                                    </RadzenRow>
                                </RadzenStack>
                            </RadzenCard>
                        }

                        @* ── FORM CAMBIO PASSWORD ──
                           Visibile solo quando mostraCambioPassword == true.
                           Validazione lato client: campi non vuoti, conferma match,
                           lunghezza >= 6, BCrypt.Verify password attuale.
                           Hash nuovo con BCrypt.HashPassword → DB via UtenteSvc.
                        *@
                        @if (mostraCambioPassword)
                        {
                            <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2 rz-p-8" Style="background: white; border-left: 5px solid #ff9800;">
                                <RadzenText TextStyle="TextStyle.H5" Class="rz-mb-6" Style="font-weight: 700; color: #e65100;">Cambia Password</RadzenText>

                                <RadzenStack Gap="1.5rem">
                                    <RadzenFormField Text="Password attuale" Style="width:100%">
                                        <RadzenPassword @bind-Value="@passwordAttuale" Style="width: 100%; height: 42px;" />
                                    </RadzenFormField>

                                    <RadzenFormField Text="Nuova password" Style="width:100%">
                                        <RadzenPassword @bind-Value="@nuovaPassword" Style="width: 100%; height: 42px;" />
                                    </RadzenFormField>

                                    <RadzenFormField Text="Conferma nuova password" Style="width:100%">
                                        <RadzenPassword @bind-Value="@confermaPassword" Style="width: 100%; height: 42px;" />
                                    </RadzenFormField>

                                    @if (!string.IsNullOrEmpty(messaggioPassword))
                                    {
                                        <RadzenAlert AlertStyle="@(successoPassword ? AlertStyle.Success : AlertStyle.Danger)" Variant="Variant.Flat">
                                            @messaggioPassword
                                        </RadzenAlert>
                                    }

                                    <RadzenRow>
                                        <RadzenColumn Size="6">
                                            <RadzenButton Text="Aggiorna password"
                                                          Click="@CambiaPassword"
                                                          Style="width: 100%; background-color: #e65100; border-radius: 8px; font-weight: bold; height: 45px;" />
                                        </RadzenColumn>
                                        <RadzenColumn Size="6">
                                            <RadzenButton Text="Annulla"
                                                          ButtonStyle="ButtonStyle.Light"
                                                          Click="@(() => { mostraCambioPassword = false; messaggioPassword = ""; })"
                                                          Style="width: 100%; border-radius: 8px; height: 45px; color: #e65100; border-color: #e65100;" />
                                        </RadzenColumn>
                                    </RadzenRow>
                                </RadzenStack>
                            </RadzenCard>
                        }

                        @* ── BACHECA "I TUOI POST" ──
                           Lista cronologica dei post creati dall'utente loggato.
                           Badge col conteggio nell'intestazione.
                           Ogni post mostra avatar 42px, nome, data (UTC→Italia) e contenuto.
                        *@
                        <RadzenCard Variant="Variant.Filled" Class="rz-border-radius-2 rz-shadow-2" Style="background: white;">
                            <div style="padding: 20px; border-bottom: 1px solid var(--brand-border);">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween">
                                    <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.7rem">
                                        <RadzenIcon Icon="article" IconColor="var(--brand-primary)" />
                                        <RadzenText TextStyle="TextStyle.H6" Class="rz-m-0" Style="font-weight: 700; color: var(--brand-primary);">
                                            I tuoi post
                                        </RadzenText>
                                    </RadzenStack>
                                    @* Badge conteggio post (stile pillola brand-primary) *@
                                    <RadzenBadge BadgeStyle="BadgeStyle.Primary"
                                                  Variant="Variant.Flat"
                                                  Class="rz-px-3 rz-py-1"
                                                  Style="background-color: var(--brand-primary); border-radius: 50px;">
                                        @(posts?.Count ?? 0)
                                    </RadzenBadge>
                                </RadzenStack>
                            </div>

                            <div style="padding: 0;">
                                @if (posts == null || !posts.Any())
                                {
                                    <RadzenText TextStyle="TextStyle.Body2" Class="rz-color-text-secondary rz-p-6 rz-text-align-center">
                                        Nessun post pubblicato.
                                    </RadzenText>
                                }
                                else
                                {
                                    @foreach (var post in posts)
                                    {
                                        <div style="padding: 20px; border-bottom: 1px solid #f0f0f0;">
                                            <RadzenStack Gap="1rem">
                                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="1rem">
                                                    @* Avatar autore 42px *@
                                                    <div style="width: 42px; height: 42px; border-radius: 50%; overflow: hidden; flex-shrink: 0; border: 2px solid var(--brand-border);">
                                                        @if (post.FotoUrl != null)
                                                        {
                                                            <img src="@post.FotoUrlBase64" style="width: 100%; height: 100%; object-fit: cover;" />
                                                        }
                                                        else
                                                        {
                                                            <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background: var(--brand-primary); color:white; font-weight:bold; font-size: 0.8rem;">
                                                                @post.Iniziali
                                                            </div>
                                                        }
                                                    </div>
                                                    <RadzenStack Gap="0">
                                                        <RadzenText TextStyle="TextStyle.Subtitle2" Class="rz-m-0" Style="font-weight: 700; color: var(--brand-primary);">
                                                            @post.Nome @post.Cognome
                                                        </RadzenText>
                                                        @* Conversione UTC → W. Europe Standard Time (Italia) *@
                                                        <RadzenText TextStyle="TextStyle.Caption" Style="color: #999;">
                                                            @TimeZoneInfo.ConvertTimeFromUtc(
                                                                DateTime.SpecifyKind(post.DataPubblicazione, DateTimeKind.Utc),
                                                                TimeZoneInfo.FindSystemTimeZoneById("W. Europe Standard Time")
                                                            ).ToString("dd MMMM yyyy, HH:mm")
                                                        </RadzenText>
                                                    </RadzenStack>
                                                </RadzenStack>
                                                <RadzenText TextStyle="TextStyle.Body1" Style="white-space: pre-wrap; line-height: 1.6; color: #2c3e50;">
                                                    @post.Contenuto
                                                </RadzenText>
                                            </RadzenStack>
                                        </div>
                                    }
                                }
                            </div>
                        </RadzenCard>

                    </RadzenStack>
                </RadzenColumn>

            </RadzenRow>
        </div>
    </div>
</div>

@code {
    // ── STATO PAGINA ──
    private Utente utente = new();                                      // Dati anagrafici utente loggato (dal DB)
    private List<PostViewModel>? posts;                                 // Post pubblicati dall'utente

    // ── MODIFICA PROFILO ──
    private bool modalitaModifica;                                       // Flag toggle form modifica
    private string modificaNome = "";
    private string modificaCognome = "";
    private string? modificaDipartimento;
    private DateTime? modificaDataNascita;
    private string? modificaFotoPreview;                                 // Preview base64 prima del salvataggio
    private byte[]? modificaFotoBytes;                                   // Byte array del file selezionato
    private string messaggioModifica = "";                               // Feedback utente

    // ── CAMBIO PASSWORD ──
    private bool mostraCambioPassword;                                   // Flag toggle form cambio password
    private string passwordAttuale = "";
    private string nuovaPassword = "";
    private string confermaPassword = "";
    private string messaggioPassword = "";
    private bool successoPassword;

    //
    // Se utente non loggato → redirect a /login.
    // Altrimenti carica dati completi dal DB (riga utente + post).
    //
    protected override async Task OnInitializedAsync()
    {
        if (Session.UtenteLoggato == null)
        {
            NavManager.NavigateTo("/login");
            return;
        }
        await CaricaProfilo();
    }

    //
    // Carica dal DB la riga completa dell'utente (UtenteSvc.GetUtenteByIdAsync)
    // e aggiorna Session.UtenteLoggato con i dati freschi.
    // Poi carica i post dell'utente (PostSvc.GetPostsByUtenteAsync).
    //
    private async Task CaricaProfilo()
    {
        try
        {
            var u = await UtenteSvc.GetUtenteByIdAsync(Session.UtenteLoggato!.UtenteId);
            if (u != null) utente = u;
            if (utente != null)
                Session.Login(utente);
            posts = await PostSvc.GetPostsByUtenteAsync(Session.UtenteLoggato.UtenteId);
        }
        catch (Exception ex)
        {
            messaggioModifica = $"Errore caricamento profilo: {ex.Message}";
            Console.WriteLine($"Errore caricamento profilo: {ex.Message}");
        }
    }

    //
    // Pre-compila i campi del form modifica con i dati correnti dell'utente.
    // Resetta foto preview/bytes. Chiude il form cambio password se aperto.
    //
    private void ApriModifica()
    {
        modificaNome = utente.Nome;
        modificaCognome = utente.Cognome;
        modificaDipartimento = utente.Dipartimento;
        modificaDataNascita = utente.DataDiNascita;
        modificaFotoPreview = null;
        modificaFotoBytes = null;
        messaggioModifica = "";
        mostraCambioPassword = false;
        modalitaModifica = true;
    }

    //
    // Chiude il form modifica profilo e pulisce il messaggio di feedback.
    //
    private void AnnullaModifica()
    {
        modalitaModifica = false;
        messaggioModifica = "";
    }

    //
    // InputFile change handler: legge il file in byte[] (max 5MB)
    // e genera anteprima base64 per preview immediata.
    //
    private void OnFotoCambiata(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            stream.CopyTo(ms);
            modificaFotoBytes = ms.ToArray();
            modificaFotoPreview = ImageHelper.ToBase64(modificaFotoBytes);
        }
    }

    //
    // Salva le modifiche profilo sul DB (UpdateUtenteAsync),
    // aggiorna Session.UtenteLoggato, ricarica profilo e post,
    // chiude il form.
    //
    private async Task SalvaModifiche()
    {
        try
        {
            utente.Nome = modificaNome;
            utente.Cognome = modificaCognome;
            utente.Dipartimento = modificaDipartimento;
            utente.DataDiNascita = modificaDataNascita;
            if (modificaFotoBytes != null)
                utente.FotoUrl = modificaFotoBytes;

            await UtenteSvc.UpdateUtenteAsync(utente);
            Session.Login(utente);

            modalitaModifica = false;
            await CaricaProfilo();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            messaggioModifica = "Errore: " + ex.Message;
        }
    }

    //
    // Prepara il form cambio password (campi vuoti) e chiude
    // il form modifica profilo se aperto.
    //
    private void ApriCambioPassword()
    {
        modalitaModifica = false;
        passwordAttuale = "";
        nuovaPassword = "";
        confermaPassword = "";
        messaggioPassword = "";
        mostraCambioPassword = true;
    }

    //
    // Validazione lato client + BCrypt.Verify della password attuale
    // + BCrypt.HashPassword per la nuova → persistenza DB.
    // Feedback visivo all'utente (alert success/danger).
    //
    private async Task CambiaPassword()
    {
        successoPassword = false;
        messaggioPassword = "";

        if (string.IsNullOrWhiteSpace(passwordAttuale) || string.IsNullOrWhiteSpace(nuovaPassword) || string.IsNullOrWhiteSpace(confermaPassword))
        {
            messaggioPassword = "Compila tutti i campi.";
            return;
        }

        if (nuovaPassword != confermaPassword)
        {
            messaggioPassword = "Le nuove password non coincidono.";
            return;
        }

        if (nuovaPassword.Length < 6)
        {
            messaggioPassword = "La nuova password deve essere almeno 6 caratteri.";
            return;
        }

        try
        {
            if (!BCrypt.Net.BCrypt.Verify(passwordAttuale, utente.Password))
            {
                messaggioPassword = "Password attuale errata.";
                return;
            }

            var hash = BCrypt.Net.BCrypt.HashPassword(nuovaPassword);
            await UtenteSvc.UpdatePasswordAsync(utente.UtenteId, hash);

            successoPassword = true;
            messaggioPassword = "Password aggiornata con successo!";
            passwordAttuale = "";
            nuovaPassword = "";
            confermaPassword = "";
        }
        catch (Exception ex)
        {
            messaggioPassword = "Errore: " + ex.Message;
        }
    }
}