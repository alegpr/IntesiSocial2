@page "/signup"
@using social_V0._0._1.Models
@using social_V0._0._1.Services

@inject UtenteService UtenteSvc
@inject NavigationManager NavManager
@inject SessionService Session
@rendermode InteractiveServer

<PageTitle>SignUp</PageTitle>

<RadzenCard class="rz-shadow-10 rz-p-12"
            style="max-width: 600px; width: 90%; border-radius: 8px; background-color: white; margin: 20px auto 50px auto;">

    <RadzenText TextStyle="TextStyle.H4" TextAlign="TextAlign.Center"
                Style="font-weight: 800; color: var(--brand-primary); margin-bottom: 2rem;">
        Registrazione
    </RadzenText>

    @if (!string.IsNullOrEmpty(messaggio))
    {
        <RadzenAlert AlertStyle="@(successo ? AlertStyle.Success : AlertStyle.Danger)" Variant="Variant.Flat" Class="rz-mb-4">
            @messaggio
        </RadzenAlert>
    }

    <RadzenTemplateForm TItem="Utente" Data="@nuovoUtente" Submit="@OnSignup">
        <RadzenStack Gap="1.5rem">

            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenFormField Text="Nome *" Style="width:100%">
                        <RadzenTextBox @bind-Value="@nuovoUtente.Nome" Name="Nome" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="Nome" Text="Richiesto" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenFormField Text="Cognome *" Style="width:100%">
                        <RadzenTextBox @bind-Value="@nuovoUtente.Cognome" Name="Cognome" Style="width: 100%;" />
                        <RadzenRequiredValidator Component="Cognome" Text="Richiesto" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenFormField Text="Email *" Style="width:100%">
                <RadzenTextBox @bind-Value="@nuovoUtente.Email" Name="Email" Style="width: 100%;" />
                <RadzenRequiredValidator Component="Email" Text="Email richiesta" />
                <RadzenEmailValidator Component="Email" Text="Formato non valido" />
            </RadzenFormField>

            <RadzenFormField Text="Password *" Style="width:100%">
                <RadzenPassword @bind-Value="@nuovoUtente.Password" Name="Password" Style="width: 100%;" />
                <RadzenRequiredValidator Component="Password" Text="Password richiesta" />
            </RadzenFormField>

            <RadzenRow>
                <RadzenColumn Size="6">
                    <RadzenFormField Text="Dipartimento" Style="width:100%">
                        <RadzenTextBox @bind-Value="@nuovoUtente.Dipartimento" MaxLength="50" Style="width: 100%;" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="6">
                    <RadzenFormField Text="Data di Nascita" Style="width:100%">
                        <RadzenDatePicker @bind-Value="@nuovoUtente.DataDiNascita" DateFormat="dd/MM/yyyy" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>

            <RadzenText TextStyle="TextStyle.Subtitle2" Style="color: #65676b;">Foto Profilo (Opzionale)</RadzenText>
            <div style="border: 1px dashed #ccc; padding: 10px; border-radius: 4px;">
                <InputFile OnChange="@OnInputFileChange" class="form-control" accept="image/*" />
            </div>

            <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                <RadzenCheckBox @bind-Value="@accettaTermini" Name="EULA" TValue="bool" />
                <RadzenLabel Component="EULA" Style="font-size: 0.9rem;">
                    Accetto i <a href="/legal/eula" style="color: var(--brand-action); font-weight: bold;">termini e condizioni</a>
                </RadzenLabel>
            </RadzenStack>

            <RadzenButton ButtonType="ButtonType.Submit" Text="REGISTRATI" Disabled="@(!accettaTermini)"
                          Style="width: 100%; background-color: var(--brand-primary); font-weight: bold; height: 48px;" />

            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="TORNA AL LOGIN"
                          Click="@(() => NavManager.NavigateTo("/login"))" Style="width: 100%; height: 48px;" />
        </RadzenStack>
    </RadzenTemplateForm>
</RadzenCard>

@code {
    private Utente nuovoUtente = new Utente();
    private string messaggio = "";
    private bool successo = false;
    private bool accettaTermini = false;
    private IBrowserFile? fileCaricato;

// Se già loggato, vai direttamente in home.
    protected override void OnInitialized()
    {
        if (Session.UtenteLoggato != null)
            NavManager.NavigateTo("/home");
    }

// Salva il file in memoria; verrà convertito in byte[] al submit.
    private void OnInputFileChange(InputFileChangeEventArgs e)
    {
        fileCaricato = e.File;
    }

    async Task OnSignup()
    {
        if (!accettaTermini) return;

        try
        {
            byte[]? fotoUrlFinale = null;

            if (fileCaricato != null)
            {
                using (var stream = fileCaricato.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024))
                using (var ms = new MemoryStream())
                {
                    await stream.CopyToAsync(ms);
                    fotoUrlFinale = ms.ToArray();
                }
            }

            await UtenteSvc.RegisterAsync(nuovoUtente, fotoUrlFinale);

            successo = true;
            messaggio = "Registrazione completata!";
            StateHasChanged();
            await Task.Delay(2000);
            NavManager.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            successo = false;
            messaggio = "Errore: " + ex.Message;
        }
    }
}