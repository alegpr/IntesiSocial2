@using Radzen.Blazor
@using social_V0._0._1.Services @* Aggiusta il namespace se necessario *@
@inject SessionService Session
@inject NavigationManager NavManager
@rendermode InteractiveServer

@if (Session.UtenteLoggato == null)
{
    <a href="/login"
       class="rz-button rz-button-primary"
       style="background-color: var(--brand-primary); border-radius: 10px; font-weight: bold; padding: 0 25px; display: inline-flex; align-items: center; justify-content: center; text-decoration: none; color: white; height: 35px;">
        Accedi
    </a>
}
else
{
    <RadzenProfileMenu Style="margin: 0;">
        <Template>
            <div style="width: 40px; height: 40px; border-radius: 50%; overflow: hidden; border: 2px solid var(--brand-primary); display: flex; align-items: center; justify-content: center; background-color: var(--brand-action); color: white; font-weight: bold; cursor: pointer;">
                @if (Session.UtenteLoggato.FotoUrl != null)
                {
                    <img src="@ToBase64(Session.UtenteLoggato.FotoUrl)" style="width: 100%; height: 100%; object-fit: cover;" alt="Profilo" />
                }
                else
                {
                    <span style="font-size: 0.9rem;">@Session.UtenteLoggato.Nome[0]@Session.UtenteLoggato.Cognome[0]</span>
                }
            </div>
        </Template>
        <ChildContent>
            <RadzenProfileMenuItem Text="Il mio profilo" Path="/profilo" Icon="account_circle" />
            <RadzenProfileMenuItem Text="Impostazioni" Path="/impostazioni" Icon="settings" />
            <RadzenProfileMenuItem Text="Esci" Path="/logout" Icon="logout" />
        </ChildContent>
    </RadzenProfileMenu>
}

@code {
    private string? ToBase64(byte[]? bytes) =>
        bytes != null ? $"data:image/jpeg;base64,{Convert.ToBase64String(bytes)}" : null;
}