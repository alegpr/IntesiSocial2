@* ────────────────────────────────────────────────────────────────────────
   NotFound.razor — Pagina 404 personalizzata.
   Route catch-all "/{**path}" cattura qualsiasi URL non mappato.
   Design:
     Card centrata con stile coerente al brand.
     Numero "404" con zero in evidenza (brand-border).
     Testo ironico coerentemente con lo spirito del social.
     Easter egg: il pulsante "Torna alla Home" scappa via
     per i primi 3 hover (MoveButton), poi si ferma.
   ──────────────────────────────────────────────────────────────────────── *@
@page "/not-found"
@page "/{**path}"

<PageTitle>404 - Link non trovato</PageTitle>

<div class="main-container">
    <div class="center-content">

        @* Card 404: stile coerente con login-card del brand *@
        <div class="rz-shadow-10 p-5 text-center bg-white"
             style="max-width: 500px; width: 90%; border-radius: var(--brand-radius); border-top: 6px solid var(--brand-primary);">

            @* Numero 404: brand-primary per "4", brand-border per "0" *@
            <div class="display-1 fw-bold mb-3" style="color: var(--brand-primary); opacity: 0.8;">
                4<span style="color: var(--brand-border)">0</span>4
            </div>

            <h2 class="mb-4" style="color: #333; font-weight: 700;">Ops! Pagina non trovata</h2>

            <p class="mb-4" style="color: #666; line-height: 1.6;">
                Abbiamo setacciato ogni riga di codice e ogni server, ma questa pagina sembra aver dato le dimissioni.
            </p>

            @* Contenitore pulsante (easter egg: scappa via per i primi 3 hover) *@
            <div class="easter-egg-container" style="height: 60px; position: relative; display: flex; align-items: center; justify-content: center;">
                <button @onmouseover="MoveButton"
                        @onclick="GoHome"
                        class="rz-button rz-button-md rz-variant-flat rz-primary"
                        style="background-color: var(--brand-primary) !important; color: white; transition: all 0.2s ease; position: relative; z-index: 10; @_buttonStyle">
                    <span class="rz-button-box">
                        <i class="rz-button-icon-left rzi">home</i>
                        <span class="rz-button-text">Torna alla Home</span>
                    </span>
                </button>
            </div>

            @* Footer ironico con lo spirito del brand *@
            <div class="mt-5 pt-3" style="border-top: 1px solid var(--brand-border);">
                <small style="color: var(--brand-primary); font-style: italic; font-weight: 500;">
                    "Il resto del social funziona meglio di questa pagina. Promesso."
                </small>
            </div>
        </div>
    </div>
</div>

@code {
    // Parametro catturato dal route catch-all "{**path}".
    [Parameter]
    public string? path { get; set; }

    // Stile CSS inline applicato al pulsante per l'effetto "scappa via".
    private string _buttonStyle = "";

    // Contatore hover; dopo 3 tentativi il pulsante smette di scappare.
    private int _attempts = 0;

    [Inject] NavigationManager Navigation { get; set; } = null!;

    //
    // Easter egg: per i primi 3 hover il pulsante si sposta in una
    // posizione random (translate X/Y). Al 4° hover torna in posizione
    // originale e rimane fermo.
    //
    private void MoveButton()
    {
        if (_attempts < 3)
        {
            var random = new Random();
            _buttonStyle = $"transform: translate({random.Next(-120, 120)}px, {random.Next(-30, 30)}px);";
            _attempts++;
        }
        else
        {
            _buttonStyle = "transform: translate(0, 0);";
        }
    }

    // Naviga alla home (radice "/") al click.
    private void GoHome() => Navigation.NavigateTo("/");
}