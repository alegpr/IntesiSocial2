@page "/Error"
@using System.Diagnostics

<PageTitle>Errore</PageTitle>

<h1 class="text-danger">Errore.</h1>
<h2 class="text-danger">Si è verificato un errore durante l'elaborazione della richiesta.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>ID Richiesta:</strong> <code>@RequestId</code>
    </p>
}

<h3>Modalità di Sviluppo</h3>
<p>
    Passando all'ambiente di <strong>Sviluppo</strong> verranno visualizzate informazioni più dettagliate sull'errore.
</p>
<p>
    <strong>L'ambiente di Sviluppo non dovrebbe essere abilitato per le applicazioni distribuite.</strong>
    Potrebbe mostrare informazioni sensibili dalle eccezioni agli utenti finali.
    Per il debug locale, abilita l'ambiente di <strong>Sviluppo</strong> impostando la variabile d'ambiente <strong>ASPNETCORE_ENVIRONMENT</strong> su <strong>Development</strong>
    e riavviando l'app.
</p>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
